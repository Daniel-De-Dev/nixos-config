# Directory Listing
alias ls 'eza --icons=auto --group-directories-first'
alias ll 'eza -l -g --icons=auto --group-directories-first --git'
alias la 'eza -a -l -g --icons=auto --group-directories-first --git'
alias tree 'eza --tree --icons=auto --group-directories-first'

# Standard Utilities
alias cat bat
alias grep rg
alias vim nvim
